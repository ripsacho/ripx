# ============================================
# Dependencies
# ============================================
node_modules/
frontend/node_modules/
backend/node_modules/
# Commit package-lock.json for reproducible installs (npm ci in CI)
yarn.lock
.pnpm-store/
.yarn/cache
.yarn/unplugged
.pnp.*

# ============================================
# Environment & Secrets (NEVER commit these)
# ============================================
.env
.env.local
.env.production
.env.development
.env.test
.env.staging
.env.*.local
# Allow .env.example as template only
!.env.example

# Credentials, keys, certificates
*.pem
*.key
*.crt
*.cert
*.p12
*.pfx
*-credentials.json
*credentials*.json
service-account*.json
GOOGLE_APPLICATION_CREDENTIALS

# ============================================
# Logs & Debug
# ============================================
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
lerna-debug.log*

# ============================================
# OS & Editor
# ============================================
.DS_Store
.DS_Store?
._*
Thumbs.db
*.swp
*.swo
*~
*.bak
*.backup

# IDE
.vscode/
.idea/
.cursor/

# ============================================
# Build outputs (generated, not needed in repo)
# ============================================
dist/
build/
frontend/dist/
frontend/build/
*.map
*.min.js
*.min.css

# Generated docs/presentation (from npm run presentation)
docs/presentation/*.html
docs/presentation/*.pdf

# Cache
.cache/
.parcel-cache/
.vite/
.turbo/
*.tsbuildinfo

# ============================================
# Database (local dev only)
# ============================================
*.sqlite
*.sqlite3
*.db

