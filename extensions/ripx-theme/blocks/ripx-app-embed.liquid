{% comment %}
  RipX App Embed — primary load via Shopify App Proxy (/apps/ripx/script.js).
  Optional fallback: if proxy fails, load a direct public script endpoint only when explicitly configured.
  This prevents local/dev stores from silently falling back to a different RipX environment.
  target: head — earlier fetch than body embeds; defer avoids blocking HTML parse.
  ?v= must stay in sync with backend storefrontScriptRuntime.js SCRIPT_VERSION (currently 1.0.17).
{% endcomment %}

<script>
  (function () {
    var shopHost = '{{ request.host }}';
    var version = '1.0.17';
    var primarySrc = 'https://' + shopHost + '/apps/ripx/script.js?v=' + version;
    var directScriptBaseUrl = {{ block.settings.direct_script_base_url | json }};
    var fallbackSrc =
      directScriptBaseUrl && String(directScriptBaseUrl).trim()
        ? String(directScriptBaseUrl).replace(/\/+$/, '') +
          '/api/track/script.js?shop=' +
          encodeURIComponent(shopHost) +
          '&v=' +
          version
        : '';
    var loaded = false;

    function loadScript(src, isFallback) {
      if (loaded) return;
      var tag = document.createElement('script');
      tag.src = src;
      tag.defer = true;
      tag.setAttribute('fetchpriority', 'high');
      tag.crossOrigin = 'anonymous';
      tag.onload = function () {
        loaded = true;
      };
      if (!isFallback) {
        tag.onerror = function () {
          if (fallbackSrc) {
            loadScript(fallbackSrc, true);
            return;
          }
          if (window.console && typeof window.console.warn === 'function') {
            window.console.warn(
              '[RipX] Failed to load storefront script from app proxy and no direct fallback URL is configured.'
            );
          }
        };
      }
      document.head.appendChild(tag);
    }

    loadScript(primarySrc, false);
  })();
</script>

{% schema %}
{
  "name": "RipX App Embed",
  "target": "head",
  "settings": [
    {
      "type": "text",
      "id": "direct_script_base_url",
      "label": "Direct script fallback base URL",
      "info": "Optional. Example: https://your-app.example.com. Leave blank in local/dev to avoid silently falling back to another environment."
    }
  ]
}
{% endschema %}
