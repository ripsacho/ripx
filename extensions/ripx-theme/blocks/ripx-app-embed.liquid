{% comment %}
  RipX App Embed — primary load via Shopify App Proxy (/apps/ripx/script.js).
  Optional fallback: if proxy fails, load a direct public script endpoint only when explicitly configured.
  This prevents local/dev stores from silently falling back to a different RipX environment.
  target: head — earlier fetch than body embeds; defer avoids blocking HTML parse.
  ?v= must stay in sync with backend storefrontScriptRuntime.js SCRIPT_VERSION (currently 1.0.31).
{% endcomment %}

<script id="ripx-app-embed-config" type="application/json">
  {
    "shopHost": {{ request.host | json }},
    "version": "1.0.31",
    "directScriptBaseUrl": {{ block.settings.direct_script_base_url | json }}
  }
</script>

<script>
  (function () {
    var shopHost = '{{ request.host }}';
    var version = '1.0.31';
    var primarySrc = 'https://' + shopHost + '/apps/ripx/script.js?v=' + version;
    var directScriptBaseUrl = {{ block.settings.direct_script_base_url | json }};
    var fallbackSrc =
      directScriptBaseUrl && String(directScriptBaseUrl).trim()
        ? String(directScriptBaseUrl).replace(/\/+$/, '') +
          '/api/track/script.js?shop=' +
          encodeURIComponent(shopHost) +
          '&v=' +
          version
        : '';
    var maxAttempts = 10;
    var attemptCount = 0;
    var ensureTimer = null;

    function hasRipx() {
      return !!(window.RipX && window.RipX.version);
    }

    function readPreviewCtx() {
      try {
        if (!window.sessionStorage) return null;
        var raw = window.sessionStorage.getItem('__ripx_preview_ctx_v1__');
        if (!raw) return null;
        var parsed = JSON.parse(raw);
        if (!parsed || typeof parsed !== 'object') return null;
        return parsed;
      } catch (_e) {
        return null;
      }
    }

    function seedPreviewCtxFromUrl() {
      try {
        if (!window.sessionStorage || !window.location || !window.location.search) return null;
        var params = new URLSearchParams(window.location.search || '');
        var previewFlag = params.get('ab_preview') === '1';
        var testId = params.get('ab_preview_test') || null;
        var variantId = params.get('ab_preview_variant') || null;
        var variantName = params.get('ab_preview_variant_name') || null;
        var tenantDomain = params.get('ab_preview_domain') || null;
        if (!(previewFlag || testId || variantId || variantName)) return null;
        var ctx = {
          preview: previewFlag,
          testId: testId,
          variantId: variantId,
          variantName: variantName,
          tenantDomain: tenantDomain,
          persistedAtMs: Date.now(),
        };
        window.sessionStorage.setItem('__ripx_preview_ctx_v1__', JSON.stringify(ctx));
        return ctx;
      } catch (_e) {
        return null;
      }
    }

    function buildPreviewUrlFromCtx(urlValue) {
      try {
        var parsed = new URL(urlValue, window.location.origin);
        var ctx = readPreviewCtx();
        if (!ctx) return parsed.toString();
        if (ctx.preview === true || ctx.preview === '1') parsed.searchParams.set('ab_preview', '1');
        if (ctx.testId) parsed.searchParams.set('ab_preview_test', String(ctx.testId));
        if (ctx.variantId) parsed.searchParams.set('ab_preview_variant', String(ctx.variantId));
        if (ctx.variantName) parsed.searchParams.set('ab_preview_variant_name', String(ctx.variantName));
        if (ctx.tenantDomain) parsed.searchParams.set('ab_preview_domain', String(ctx.tenantDomain));
        return parsed.toString();
      } catch (_e) {
        return String(urlValue || '');
      }
    }

    function redirectToPreviewBootstrapIfNeeded() {
      try {
        if (hasRipx()) return false;
        var ctx = readPreviewCtx();
        if (!ctx || !(ctx.preview || ctx.testId || ctx.variantId || ctx.variantName)) return false;
        var path = String(window.location.pathname || '').toLowerCase();
        if (path.indexOf('/apps/ripx/preview-bootstrap') === 0) return false;
        if (path.indexOf('/apps/ripx/preview-bootstrap-v2') === 0) return false;
        var previewTarget = buildPreviewUrlFromCtx(window.location.href);
        if (!previewTarget) return false;
        var next =
          'https://' +
          shopHost +
          '/apps/ripx/preview-bootstrap-v2?url=' +
          encodeURIComponent(previewTarget);
        window.location.replace(next);
        return true;
      } catch (_e) {
        return false;
      }
    }

    function withPreviewBust(src) {
      if (!src) return '';
      try {
        var parsed = new URL(src, window.location.origin);
        var ctx = readPreviewCtx();
        if (ctx && (ctx.preview || ctx.testId || ctx.variantId || ctx.variantName)) {
          parsed.searchParams.set('ripx_preview_bust', String(Date.now()));
        }
        return parsed.toString();
      } catch (_e) {
        return src;
      }
    }

    function hasScriptTagFor(src) {
      if (!src) return false;
      var normalized = String(src).split('?')[0];
      try {
        return Array.prototype.slice.call(document.scripts || []).some(function (s) {
          var current = String((s && s.src) || '').split('?')[0];
          return !!current && current === normalized;
        });
      } catch (_e) {
        return false;
      }
    }

    function appendScript(src, isFallback) {
      if (!src || hasScriptTagFor(src)) return;
      var tag = document.createElement('script');
      tag.src = src;
      tag.defer = true;
      tag.setAttribute('fetchpriority', 'high');
      tag.onload = function () {
        if (hasRipx()) stopEnsure();
      };
      tag.onerror = function () {
        if (!isFallback && fallbackSrc) {
          appendScript(withPreviewBust(fallbackSrc), true);
        }
      };
      (document.head || document.documentElement || document.body).appendChild(tag);
    }

    function stopEnsure() {
      if (ensureTimer) {
        clearInterval(ensureTimer);
        ensureTimer = null;
      }
    }

    function ensureLoaded() {
      if (hasRipx()) {
        stopEnsure();
        return;
      }
      attemptCount += 1;
      appendScript(withPreviewBust(primarySrc), false);
      if (fallbackSrc) appendScript(withPreviewBust(fallbackSrc), true);
      if (attemptCount >= maxAttempts) {
        stopEnsure();
        if (redirectToPreviewBootstrapIfNeeded()) return;
        if (window.console && typeof window.console.warn === 'function') {
          window.console.warn(
            '[RipX] Storefront script did not initialize after retries. Check app embed status and proxy route.'
          );
        }
      }
    }

    seedPreviewCtxFromUrl();
    ensureLoaded();
    ensureTimer = setInterval(ensureLoaded, 1500);
    window.addEventListener('pageshow', function () {
      if (!hasRipx()) ensureLoaded();
    });
  })();
</script>

{% schema %}
{
  "name": "RipX App Embed",
  "target": "head",
  "javascript": "ripx-app-embed-loader.js",
  "settings": [
    {
      "type": "text",
      "id": "direct_script_base_url",
      "label": "Direct script fallback base URL",
      "info": "Optional. Example: https://your-app.example.com. Leave blank in local/dev to avoid silently falling back to another environment."
    }
  ]
}
{% endschema %}
