{% comment %}
  RipX App Embed — primary load via Shopify App Proxy (/apps/ripx/script.js).
  Optional fallback: if proxy fails, load a direct public script endpoint only when explicitly configured.
  This prevents local/dev stores from silently falling back to a different RipX environment.
  target: head — earlier fetch than body embeds; defer avoids blocking HTML parse.
  ?v= must stay in sync with backend storefrontScriptRuntime.js SCRIPT_VERSION (currently 1.0.28).
{% endcomment %}

<script>
  (function () {
    var shopHost = '{{ request.host }}';
    var version = '1.0.28';
    var primarySrc = 'https://' + shopHost + '/apps/ripx/script.js?v=' + version;
    var directScriptBaseUrl = {{ block.settings.direct_script_base_url | json }};
    var fallbackSrc =
      directScriptBaseUrl && String(directScriptBaseUrl).trim()
        ? String(directScriptBaseUrl).replace(/\/+$/, '') +
          '/api/track/script.js?shop=' +
          encodeURIComponent(shopHost) +
          '&v=' +
          version
        : '';
    var maxAttempts = 10;
    var attemptCount = 0;
    var ensureTimer = null;

    function hasRipx() {
      return !!(window.RipX && window.RipX.version);
    }

    function readPreviewCtx() {
      try {
        if (!window.sessionStorage) return null;
        var raw = window.sessionStorage.getItem('__ripx_preview_ctx_v1__');
        if (!raw) return null;
        var parsed = JSON.parse(raw);
        if (!parsed || typeof parsed !== 'object') return null;
        return parsed;
      } catch (_e) {
        return null;
      }
    }

    function withPreviewBust(src) {
      if (!src) return '';
      try {
        var parsed = new URL(src, window.location.origin);
        var ctx = readPreviewCtx();
        if (ctx && (ctx.preview || ctx.testId || ctx.variantId || ctx.variantName)) {
          parsed.searchParams.set('ripx_preview_bust', String(Date.now()));
        }
        return parsed.toString();
      } catch (_e) {
        return src;
      }
    }

    function hasScriptTagFor(src) {
      if (!src) return false;
      var normalized = String(src).split('?')[0];
      try {
        return Array.prototype.slice.call(document.scripts || []).some(function (s) {
          var current = String((s && s.src) || '').split('?')[0];
          return !!current && current === normalized;
        });
      } catch (_e) {
        return false;
      }
    }

    function appendScript(src, isFallback) {
      if (!src || hasScriptTagFor(src)) return;
      var tag = document.createElement('script');
      tag.src = src;
      tag.defer = true;
      tag.setAttribute('fetchpriority', 'high');
      tag.onload = function () {
        if (hasRipx()) stopEnsure();
      };
      tag.onerror = function () {
        if (!isFallback && fallbackSrc) {
          appendScript(withPreviewBust(fallbackSrc), true);
        }
      };
      (document.head || document.documentElement || document.body).appendChild(tag);
    }

    function stopEnsure() {
      if (ensureTimer) {
        clearInterval(ensureTimer);
        ensureTimer = null;
      }
    }

    function ensureLoaded() {
      if (hasRipx()) {
        stopEnsure();
        return;
      }
      attemptCount += 1;
      appendScript(withPreviewBust(primarySrc), false);
      if (fallbackSrc) appendScript(withPreviewBust(fallbackSrc), true);
      if (attemptCount >= maxAttempts) {
        stopEnsure();
        if (window.console && typeof window.console.warn === 'function') {
          window.console.warn(
            '[RipX] Storefront script did not initialize after retries. Check app embed status and proxy route.'
          );
        }
      }
    }

    ensureLoaded();
    ensureTimer = setInterval(ensureLoaded, 1500);
    window.addEventListener('pageshow', function () {
      if (!hasRipx()) ensureLoaded();
    });
  })();
</script>

{% schema %}
{
  "name": "RipX App Embed",
  "target": "head",
  "settings": [
    {
      "type": "text",
      "id": "direct_script_base_url",
      "label": "Direct script fallback base URL",
      "info": "Optional. Example: https://your-app.example.com. Leave blank in local/dev to avoid silently falling back to another environment."
    }
  ]
}
{% endschema %}
