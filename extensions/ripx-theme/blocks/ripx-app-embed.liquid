{% comment %}
  RipX App Embed — primary load via Shopify App Proxy (/apps/ripx/script.js).
  Optional fallback: if proxy fails, load a direct public script endpoint only when explicitly configured.
  This prevents local/dev stores from silently falling back to a different RipX environment.
  target: head — the primary runtime is parser-blocking so the server bootstrap can run before body paint.
  ?v= must stay in sync with backend storefrontScriptRuntime.js SCRIPT_VERSION (currently 1.0.46).
{% endcomment %}

<script>
  (function () {
    var storageKey = '__ripx_price_af_hint_v1__';
    var shopHost = '{{ request.host }}';
    var version = '1.0.46';
    var styleId = 'ripx-anti-flicker-style';
    function installPreviewGuardIfNeeded() {
      try {
        if (!document.documentElement || !window.location) return false;
        var params = new URLSearchParams(window.location.search || '');
        var isPreview =
          params.get('ab_preview') === '1' ||
          !!params.get('ab_preview_test') ||
          !!params.get('ab_preview_variant');
        if (!isPreview) return false;
        var styleEl = document.getElementById(styleId);
        if (!styleEl) {
          styleEl = document.createElement('style');
          styleEl.id = styleId;
          (document.head || document.documentElement).appendChild(styleEl);
        }
        styleEl.textContent = 'html[data-ripx-af="strict"] body{opacity:0 !important;}';
        document.documentElement.setAttribute('data-ripx-af', 'strict');
        window.__RIPX_INLINE_PREVIEW_AF__ = { active: true, at: Date.now() };
        setTimeout(function () {
          if (
            window.__RIPX_INLINE_PREVIEW_AF__ &&
            window.__RIPX_INLINE_PREVIEW_AF__.active &&
            document.documentElement.getAttribute('data-ripx-af') === 'strict'
          ) {
            document.documentElement.removeAttribute('data-ripx-af');
            window.__RIPX_INLINE_PREVIEW_AF__.active = false;
            window.__RIPX_INLINE_PREVIEW_AF__.releasedBy = 'inline_preview_timeout';
          }
        }, 1800);
        return true;
      } catch (_ePreviewAf) {
        return false;
      }
    }
    function isSafeSelector(selector) {
      var value = String(selector || '').trim();
      if (!value || value.length > 300) return false;
      if (value.indexOf('{') !== -1 || value.indexOf('}') !== -1) return false;
      for (var i = 0; i < value.length; i += 1) {
        if (value.charCodeAt(i) < 32) return false;
      }
      return true;
    }
    try {
      if (installPreviewGuardIfNeeded()) return;
      if (!window.sessionStorage || !document.documentElement) return;
      var raw = window.sessionStorage.getItem(storageKey);
      if (!raw) return;
      var hint = JSON.parse(raw);
      if (!hint || hint.version !== version || hint.shopHost !== window.location.hostname) return;
      if (!hint.expiresAtMs || Date.now() > Number(hint.expiresAtMs)) {
        window.sessionStorage.removeItem(storageKey);
        return;
      }
      var selectors = Array.isArray(hint.selectors) ? hint.selectors.filter(isSafeSelector) : [];
      if (!selectors.length) return;
      var styleEl = document.getElementById(styleId);
      if (!styleEl) {
        styleEl = document.createElement('style');
        styleEl.id = styleId;
        (document.head || document.documentElement).appendChild(styleEl);
      }
      styleEl.textContent = selectors
        .slice(0, 80)
        .map(function (selector) {
          return 'html[data-ripx-af="price"] ' + selector + '{opacity:0 !important;}';
        })
        .join('');
      document.documentElement.setAttribute('data-ripx-af', 'price');
      window.__RIPX_INLINE_PRICE_AF__ = { active: true, at: Date.now(), selectors: selectors.length };
      setTimeout(function () {
        if (
          window.__RIPX_INLINE_PRICE_AF__ &&
          window.__RIPX_INLINE_PRICE_AF__.active &&
          document.documentElement.getAttribute('data-ripx-af') === 'price' &&
          !(window.RipX && window.RipX.version)
        ) {
          document.documentElement.removeAttribute('data-ripx-af');
          window.__RIPX_INLINE_PRICE_AF__.active = false;
          window.__RIPX_INLINE_PRICE_AF__.releasedBy = 'inline_timeout';
        }
      }, Math.max(300, Math.min(1200, Number(hint.timeoutMs) || 900)));
    } catch (_e) {}
  })();
</script>

{% # theme-check-disable RemoteAsset, ParserBlockingScript %}
<link rel="preconnect" href="https://{{ request.host }}" crossorigin>
<script
  id="ripx-storefront-runtime"
  src="https://{{ request.host }}/apps/ripx/script.js?v=1.0.46"
  crossorigin="anonymous"
  fetchpriority="high"
></script>
{% # theme-check-enable RemoteAsset, ParserBlockingScript %}

<script id="ripx-app-embed-config" type="application/json">
  {
    "shopHost": {{ request.host | json }},
    "version": "1.0.46",
    "directScriptBaseUrl": {{ block.settings.direct_script_base_url | json }}
  }
</script>

<script>
  (function () {
    if (window.__RIPX_APP_EMBED_LOADER__) return;
    window.__RIPX_APP_EMBED_LOADER__ = true;

    var shopHost = '{{ request.host }}';
    var version = '1.0.46';
    var primarySrc = 'https://' + shopHost + '/apps/ripx/script.js?v=' + version;
    var directScriptBaseUrl = {{ block.settings.direct_script_base_url | json }};
    var fallbackSrc =
      directScriptBaseUrl && String(directScriptBaseUrl).trim()
        ? String(directScriptBaseUrl).replace(/\/+$/, '') +
          '/api/track/script.js?shop=' +
          encodeURIComponent(shopHost) +
          '&v=' +
          version
        : '';
    var maxAttempts = 10;
    var attemptCount = 0;
    var ensureTimer = null;

    function hasRipx() {
      return !!(window.RipX && window.RipX.version);
    }

    function readPreviewCtx() {
      try {
        if (!window.sessionStorage) return null;
        var raw = window.sessionStorage.getItem('__ripx_preview_ctx_v1__');
        if (!raw) return null;
        var parsed = JSON.parse(raw);
        if (!parsed || typeof parsed !== 'object') return null;
        return parsed;
      } catch (_e) {
        return null;
      }
    }

    function seedPreviewCtxFromUrl() {
      try {
        if (!window.sessionStorage || !window.location || !window.location.search) return null;
        var params = new URLSearchParams(window.location.search || '');
        var simplePreview = params.get('ab_preview_simple') === '1';
        var previewFlag = params.get('ab_preview') === '1';
        var testId = params.get('ab_preview_test') || null;
        var variantId = params.get('ab_preview_variant') || null;
        var variantName = params.get('ab_preview_variant_name') || null;
        var tenantDomain = params.get('ab_preview_domain') || null;
        if (!(previewFlag || testId || variantId || variantName)) return null;
        if (params.get('ab_preview_reset') === '1') {
          try {
            window.sessionStorage.removeItem('__ripx_preview_ctx_v1__');
            if (testId) window.sessionStorage.removeItem('ripx_preview_variant_cache_' + String(testId));
            for (var i = window.sessionStorage.length - 1; i >= 0; i -= 1) {
              var key = window.sessionStorage.key(i);
              if (key && key.indexOf('ripx_preview_variant_cache_') === 0) {
                window.sessionStorage.removeItem(key);
              }
            }
          } catch (_eReset) {}
        }
        var ctx = {
          preview: previewFlag,
          testId: testId,
          variantId: variantId,
          variantName: variantName,
          tenantDomain: tenantDomain,
          simple: simplePreview,
          sessionId: params.get('ab_preview_session') || null,
          persistedAtMs: Date.now(),
        };
        window.sessionStorage.setItem('__ripx_preview_ctx_v1__', JSON.stringify(ctx));
        return ctx;
      } catch (_e) {
        return null;
      }
    }

    function buildPreviewUrlFromCtx(urlValue) {
      try {
        var parsed = new URL(urlValue, window.location.origin);
        var ctx = readPreviewCtx();
        if (!ctx) return parsed.toString();
        if (ctx.preview === true || ctx.preview === '1') parsed.searchParams.set('ab_preview', '1');
        if (ctx.testId) parsed.searchParams.set('ab_preview_test', String(ctx.testId));
        if (ctx.variantId) parsed.searchParams.set('ab_preview_variant', String(ctx.variantId));
        if (ctx.variantName) parsed.searchParams.set('ab_preview_variant_name', String(ctx.variantName));
        if (ctx.tenantDomain) parsed.searchParams.set('ab_preview_domain', String(ctx.tenantDomain));
        if (ctx.simple === true || ctx.simple === '1') parsed.searchParams.set('ab_preview_simple', '1');
        if (ctx.sessionId) parsed.searchParams.set('ab_preview_session', String(ctx.sessionId));
        return parsed.toString();
      } catch (_e) {
        return String(urlValue || '');
      }
    }

    function redirectToPreviewBootstrapIfNeeded() {
      try {
        if (hasRipx()) return false;
        var ctx = readPreviewCtx();
        if (!ctx || !(ctx.preview || ctx.testId || ctx.variantId || ctx.variantName)) return false;
        var currentParams = new URLSearchParams(window.location.search || '');
        if (currentParams.get('ab_preview_simple') === '1') return false;
        var path = String(window.location.pathname || '').toLowerCase();
        if (path.indexOf('/apps/ripx/preview-bootstrap') === 0) return false;
        if (path.indexOf('/apps/ripx/preview-bootstrap-v2') === 0) return false;
        if (path.indexOf('/apps/ripx/price-preview-bootstrap') === 0) return false;
        var previewTarget = buildPreviewUrlFromCtx(window.location.href);
        if (!previewTarget) return false;
        var next =
          'https://' +
          shopHost +
          '/apps/ripx/preview-bootstrap-v2?url=' +
          encodeURIComponent(previewTarget);
        window.location.replace(next);
        return true;
      } catch (_e) {
        return false;
      }
    }

    function withPreviewBust(src) {
      if (!src) return '';
      try {
        var parsed = new URL(src, window.location.origin);
        var ctx = readPreviewCtx();
        if (ctx && (ctx.preview || ctx.testId || ctx.variantId || ctx.variantName)) {
          parsed.searchParams.set('ripx_preview_bust', String(Date.now()));
        }
        return parsed.toString();
      } catch (_e) {
        return src;
      }
    }

    function hasScriptTagFor(src) {
      if (!src) return false;
      var normalized = String(src).split('?')[0];
      try {
        return Array.prototype.slice.call(document.scripts || []).some(function (s) {
          var current = String((s && s.src) || '').split('?')[0];
          return !!current && current === normalized;
        });
      } catch (_e) {
        return false;
      }
    }

    function appendScript(src, isFallback) {
      if (!src || hasScriptTagFor(src)) return;
      var tag = document.createElement('script');
      tag.src = src;
      tag.defer = true;
      tag.setAttribute('fetchpriority', 'high');
      tag.onload = function () {
        if (hasRipx()) {
          try {
            window.__RIPX_APP_EMBED_LOADER_STATUS__ = {
              ok: true,
              version: window.RipX.version,
              source: isFallback ? 'direct' : 'app_proxy',
              preview: !!readPreviewCtx(),
              at: Date.now(),
            };
          } catch (_eStatusOk) {}
          stopEnsure();
        }
      };
      tag.onerror = function () {
        try {
          window.__RIPX_APP_EMBED_LOADER_STATUS__ = {
            ok: false,
            failedSrc: src,
            fallback: !!isFallback,
            preview: !!readPreviewCtx(),
            at: Date.now(),
          };
        } catch (_eStatusFail) {}
        if (!isFallback && fallbackSrc) {
          appendScript(withPreviewBust(fallbackSrc), true);
        }
      };
      (document.head || document.documentElement || document.body).appendChild(tag);
    }

    function stopEnsure() {
      if (ensureTimer) {
        clearInterval(ensureTimer);
        ensureTimer = null;
      }
    }

    function ensureLoaded() {
      if (hasRipx()) {
        try {
          window.__RIPX_APP_EMBED_LOADER_STATUS__ = {
            ok: true,
            version: window.RipX.version,
            preview: !!readPreviewCtx(),
            at: Date.now(),
          };
        } catch (_eStatusExisting) {}
        stopEnsure();
        return;
      }
      attemptCount += 1;
      appendScript(withPreviewBust(primarySrc), false);
      if (fallbackSrc) appendScript(withPreviewBust(fallbackSrc), true);
      if (attemptCount >= maxAttempts) {
        stopEnsure();
        if (redirectToPreviewBootstrapIfNeeded()) return;
        try {
          window.__RIPX_APP_EMBED_LOADER_STATUS__ = {
            ok: false,
            reason: 'runtime_missing_after_retries',
            preview: !!readPreviewCtx(),
            hasEmbedConfig: !!document.getElementById('ripx-app-embed-config'),
            primarySrc: primarySrc,
            fallbackConfigured: !!fallbackSrc,
            at: Date.now(),
          };
        } catch (_eStatusRetries) {}
        if (window.console && typeof window.console.warn === 'function') {
          window.console.warn(
            '[RipX] Storefront script did not initialize after retries. Check app embed status and proxy route.'
          );
        }
      }
    }

    seedPreviewCtxFromUrl();
    ensureLoaded();
    ensureTimer = setInterval(ensureLoaded, 1500);
    window.addEventListener('pageshow', function () {
      if (!hasRipx()) ensureLoaded();
    });
  })();
</script>

{% schema %}
{
  "name": "RipX App Embed",
  "target": "head",
  "javascript": "ripx-app-embed-loader.js",
  "settings": [
    {
      "type": "text",
      "id": "direct_script_base_url",
      "label": "Direct script fallback base URL",
      "info": "Optional. Example: https://your-app.example.com. Leave blank in local/dev to avoid silently falling back to another environment."
    }
  ]
}
{% endschema %}
