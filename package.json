{
  "name": "ripx",
  "version": "1.0.0",
  "description": "RipX - Professional AB Testing Platform for Shopify Stores",
  "main": "backend/src/app.js",
  "scripts": {
    "dev": "concurrently \"npm run dev:backend\" \"npm run dev:frontend\"",
    "dev:backend": "nodemon backend/src/app.js",
    "dev:frontend": "cd frontend && npm run dev",
    "build": "npm run build:frontend",
    "build:frontend": "cd frontend && npm run build",
    "start": "node backend/src/app.js",
    "migrate": "cd backend && node migrations/run.js",
    "test": "jest",
    "test:backend": "cd backend && jest",
    "test:frontend": "cd frontend && npm test",
    "lint": "eslint backend/src --ext .js",
    "lint:fix": "eslint backend/src --ext .js --fix",
    "format": "prettier --write \"**/*.{js,jsx,json,md}\"",
    "format:check": "prettier --check \"**/*.{js,jsx,json,md}\""
  },
  "keywords": [
    "ripx",
    "shopify",
    "ab-testing",
    "a-b-testing",
    "ecommerce",
    "analytics",
    "conversion-optimization",
    "split-testing",
    "variant-testing"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@shopify/shopify-api": "^9.0.0",
    "bcrypt": "^5.1.1",
    "body-parser": "^1.20.2",
    "cookie-parser": "^1.4.6",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "pg": "^8.11.3",
    "redis": "^4.6.10",
    "uuid": "^9.0.1"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "eslint": "^8.57.1",
    "eslint-plugin-react": "^7.33.2",
    "eslint-plugin-react-hooks": "^4.6.0",
    "jest": "^29.7.0",
    "nodemon": "^3.0.2",
    "prettier": "^3.7.4",
    "supertest": "^6.3.3"
  }
}
