{
  "name": "ripx",
  "version": "1.0.0",
  "description": "RipX - Professional AB Testing Platform for Shopify Stores",
  "main": "backend/src/app.js",
  "scripts": {
    "dev": "concurrently \"npm run dev:backend\" \"npm run dev:frontend\"",
    "dev:backend": "nodemon",
    "dev:frontend": "cd frontend && npm run dev",
    "install:all": "npm install && npm --prefix frontend install && npm --prefix extensions/ripx-checkout-discount install && npm --prefix extensions/ripx-cart-transform install && npm --prefix extensions/ripx-checkout-ui install && npm --prefix extensions/ripx-payment-customization install && npm --prefix extensions/ripx-delivery-customization install",
    "dev:db": "docker compose -f docker-compose.dev.yml up -d",
    "dev:db:stop": "docker compose -f docker-compose.dev.yml down",
    "build": "npm run build:frontend",
    "build:frontend": "cd frontend && npm run build",
    "start": "node backend/src/app.js",
    "migrate": "cd backend && node migrations/run.js",
    "migrate:mark-applied": "cd backend && node migrations/mark-applied.js",
    "ensure-superadmin": "node backend/scripts/ensureSuperAdmin.js",
    "remove-unlinked-tenants": "node backend/scripts/removeUnlinkedTenants.js",
    "encrypt:integration-secrets": "node backend/scripts/encryptIntegrationSecrets.js",
    "index-support-kb": "node backend/scripts/indexSupportKb.js",
    "verify:analytics-queries": "node backend/scripts/explainAnalyticsQueries.js",
    "deploy:server": "bash scripts/deploy-production.sh",
    "seed:dummy": "node backend/scripts/seed-dummy-data.js",
    "test": "npm run test:backend && npm run test:frontend",
    "test:backend": "cd backend && jest",
    "test:frontend": "cd frontend && npm test",
    "lint": "npm run lint:backend && npm run lint:frontend",
    "lint:backend": "eslint backend/src --ext .js",
    "lint:frontend": "cd frontend && eslint src --ext .js,.jsx",
    "lint:fix": "npm run lint:fix:backend && npm run lint:fix:frontend",
    "lint:fix:backend": "eslint backend/src --ext .js --fix",
    "lint:fix:frontend": "cd frontend && eslint src --ext .js,.jsx --fix",
    "format": "prettier --write \"**/*.{js,jsx,json,md}\"",
    "format:check": "prettier --check \"**/*.{js,jsx,json,md}\"",
    "prepare": "husky",
    "validate": "npm run lint && npm run test && npm run build",
    "shopify:dev": "shopify app dev",
    "shopify:dev:local": "shopify app dev --config shopify.app.local.toml",
    "shopify:dev:production": "shopify app dev --config shopify.app.production.toml",
    "shopify:dev:local:safe": "npm run shopify:guard:local && npm run shopify:dev:local",
    "shopify:dev:production:safe": "npm run shopify:guard:production && npm run shopify:dev:production",
    "shopify:dev:localhost": "shopify app dev --use-localhost",
    "shopify:deploy:local": "shopify app deploy --config shopify.app.local.toml",
    "shopify:deploy:production": "shopify app deploy --config shopify.app.production.toml",
    "shopify:deploy:local:safe": "npm run shopify:guard:local && npm run shopify:extensions:prepare && npm run shopify:deploy:local",
    "shopify:deploy:production:safe": "npm run shopify:guard:production && npm run shopify:extensions:prepare && npm run shopify:deploy:production",
    "shopify:guard:local": "node scripts/verify-shopify-config-match.js --config shopify.app.local.toml",
    "shopify:guard:production": "node scripts/verify-shopify-config-match.js --config shopify.app.production.toml",
    "shopify:checkout-discount:install": "cd extensions/ripx-checkout-discount && npm install",
    "shopify:checkout-discount:sync-config": "node scripts/write-ripx-checkout-config.js --target=discount",
    "shopify:checkout-discount:typegen": "shopify app function typegen --path extensions/ripx-checkout-discount",
    "shopify:checkout-discount:build": "shopify app function build --path extensions/ripx-checkout-discount",
    "shopify:checkout-discount:prepare": "npm run shopify:checkout-discount:install && npm run shopify:checkout-discount:sync-config && npm run shopify:checkout-discount:typegen && npm run shopify:checkout-discount:build",
    "shopify:checkout-ui:install": "cd extensions/ripx-checkout-ui && npm install",
    "shopify:checkout-ui:sync-config": "node scripts/write-ripx-checkout-config.js --target=ui",
    "shopify:checkout-ui:prepare": "npm run shopify:checkout-ui:install && npm run shopify:checkout-ui:sync-config",
    "shopify:extensions:prepare": "npm run shopify:checkout-discount:prepare && npm run shopify:checkout-ui:prepare && npm run shopify:cart-transform:prepare && npm run shopify:payment-customization:prepare && npm run shopify:delivery-customization:prepare",
    "shopify:cart-transform:install": "cd extensions/ripx-cart-transform && npm install",
    "shopify:cart-transform:typegen": "shopify app function typegen --path extensions/ripx-cart-transform",
    "shopify:cart-transform:build": "shopify app function build --path extensions/ripx-cart-transform",
    "shopify:cart-transform:prepare": "npm run shopify:cart-transform:install && npm run shopify:cart-transform:typegen && npm run shopify:cart-transform:build",
    "shopify:payment-customization:install": "cd extensions/ripx-payment-customization && npm install",
    "shopify:payment-customization:typegen": "shopify app function typegen --path extensions/ripx-payment-customization",
    "shopify:payment-customization:build": "shopify app function build --path extensions/ripx-payment-customization",
    "shopify:payment-customization:prepare": "npm run shopify:payment-customization:install && npm run shopify:payment-customization:typegen && npm run shopify:payment-customization:build",
    "shopify:delivery-customization:install": "cd extensions/ripx-delivery-customization && npm install",
    "shopify:delivery-customization:typegen": "shopify app function typegen --path extensions/ripx-delivery-customization",
    "shopify:delivery-customization:build": "shopify app function build --path extensions/ripx-delivery-customization",
    "shopify:delivery-customization:prepare": "npm run shopify:delivery-customization:install && npm run shopify:delivery-customization:typegen && npm run shopify:delivery-customization:build",
    "dev:align-tunnel": "node scripts/dev-align-tunnel.js",
    "dev:switch-tunnel": "node scripts/dev-switch-tunnel.js",
    "verify:price-pipeline": "node scripts/verify-price-pipeline.js",
    "verify:shipping-readiness": "node scripts/verify-shipping-readiness.js",
    "verify:price-assignment-readiness": "node scripts/verify-price-assignment-readiness.js",
    "verify:price-go-no-go": "node scripts/verify-price-go-no-go.js",
    "verify:price-go-no-go:strict": "node scripts/verify-price-go-no-go.js --strict",
    "audit": "npm audit && npm --prefix frontend audit && npm run audit:extensions",
    "audit:extensions": "npm --prefix extensions/ripx-checkout-discount audit && npm --prefix extensions/ripx-cart-transform audit && npm --prefix extensions/ripx-checkout-ui audit && npm --prefix extensions/ripx-payment-customization audit && npm --prefix extensions/ripx-delivery-customization audit",
    "presentation": "npx @marp-team/marp-cli docs/presentation/PRESENTATION.md -o docs/presentation/PRESENTATION.html --allow-local-files",
    "presentation:pdf": "npx @marp-team/marp-cli docs/presentation/PRESENTATION.md -o docs/presentation/PRESENTATION.pdf --allow-local-files",
    "speech:pdf": "npx @marp-team/marp-cli docs/presentation/SPEECH_DECK.md -o docs/presentation/SPEECH.pdf --allow-local-files --no-stdin"
  },
  "keywords": [
    "ripx",
    "shopify",
    "ab-testing",
    "a-b-testing",
    "ecommerce",
    "analytics",
    "conversion-optimization",
    "split-testing",
    "variant-testing"
  ],
  "author": "",
  "license": "MIT",
  "engines": {
    "node": ">=20.17.0",
    "npm": ">=9.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/your-org/ripx.git"
  },
  "homepage": "https://github.com/your-org/ripx#readme",
  "bugs": {
    "url": "https://github.com/your-org/ripx/issues"
  },
  "dependencies": {
    "@google-cloud/bigquery": "^7.3.0",
    "@shopify/shopify-api": "^9.0.0",
    "@socket.io/redis-adapter": "^8.3.0",
    "bcrypt": "^5.1.1",
    "body-parser": "^1.20.2",
    "bull": "^4.16.5",
    "compression": "^1.8.1",
    "connect-redis": "^7.1.1",
    "cookie-parser": "^1.4.6",
    "cors": "^2.8.6",
    "dotenv": "^16.4.0",
    "express": "^4.21.0",
    "express-rate-limit": "^8.2.0",
    "express-session": "^1.19.0",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.2",
    "multer": "^1.4.5-lts.1",
    "nodemailer": "^8.0.1",
    "openai": "^4.73.0",
    "pg": "^8.18.0",
    "redis": "^4.6.10",
    "socket.io": "^4.8.3",
    "socket.io-client": "^4.8.3",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1",
    "uuid": "^10.0.0"
  },
  "devDependencies": {
    "concurrently": "^9.2.1",
    "eslint": "^8.57.1",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-react": "^7.33.2",
    "eslint-plugin-react-hooks": "^4.6.0",
    "husky": "^9.1.7",
    "jest": "^29.7.0",
    "lint-staged": "^16.2.7",
    "nodemon": "^3.0.2",
    "prettier": "^3.8.1",
    "supertest": "^6.3.3"
  },
  "lint-staged": {
    "backend/**/*.js": [
      "eslint --fix"
    ],
    "frontend/src/**/*.{js,jsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{js,jsx,json,md}": [
      "prettier --write"
    ]
  },
  "overrides": {
    "tar": "^7.2.0",
    "minimatch": "^10.2.1"
  }
}
