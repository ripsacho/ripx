# RipX Environment Variables
# Copy this file to .env and fill in your values
# Supports both Shopify and standalone (non-Shopify) sites

# ============================================
# Required Variables
# ============================================

# Platform mode: set RIPX_STANDALONE_ONLY=true to disable Shopify (standalone sites only)
# RIPX_STANDALONE_ONLY=true

# Shopify API Credentials (required unless RIPX_STANDALONE_ONLY=true)
# Use different credentials per environment (local/dev vs production), but keep each environment internally consistent:
# - SHOPIFY_API_KEY must match the app Client ID used by that environment's Shopify CLI config file
#   (shopify.app.local.toml or shopify.app.production.toml)
# - SHOPIFY_API_SECRET must be the matching secret for that same app.
SHOPIFY_API_KEY=your_shopify_api_key_here
SHOPIFY_API_SECRET=your_shopify_api_secret_here
# App Proxy script: must match Partner Dashboard → your app → Client credentials → Client secret (same app as App Proxy). Leading/trailing spaces are trimmed.
# Optional (non-production only): RIPX_APP_PROXY_SKIP_VERIFY=true skips signature verification so the script loads while you fix the secret.
# Match app release scopes. read_products covers products and collections in the Admin API (there is no read_collections OAuth scope). Order should match shopify.app.toml.
SHOPIFY_SCOPES=read_cart_transforms,read_content,read_delivery_customizations,read_discounts,read_online_store_pages,read_orders,read_payment_customizations,read_products,read_shipping,write_cart_transforms,write_delivery_customizations,write_discounts,write_payment_customizations,write_products,write_shipping

# Optional Shopify Access Token (development fallback)
# SHOPIFY_ACCESS_TOKEN=shpat_your_dev_token

# Database Configuration
DATABASE_URL=postgresql://username:password@localhost:5432/ripx_db
# For docker-compose.dev.yml: postgresql://ripx:ripx@localhost:5432/ripx_dev
# Alternative: MongoDB
# MONGODB_URI=mongodb://localhost:27017/ripx_db

# JWT Secret (generate a strong random string, 32+ chars for production)
# Example: openssl rand -hex 32
JWT_SECRET=your_jwt_secret_here_generate_strong_random_string

# Application URL (backend). Trailing slashes are stripped when building API URLs.
# CSP connect-src and production CORS default use the origin only (scheme + host + port); a path here is ignored for those headers.
APP_URL=http://localhost:3000
# Frontend URL (set when frontend is on a different origin). Added to CSP connect-src when it differs from APP_URL. Used for magic-link login, connect links, and Shopify OAuth redirect_uri fallback when the request host cannot be used.
# Tunnel (Cloudflare/ngrok): set APP_URL to your tunnel URL (e.g. https://xxx.trycloudflare.com). In Shopify Partner Dashboard set Application URL and Allowed redirection URL(s) to the same URL. Frontend sends callback_base so redirect_uri matches; tunnel suffixes (.trycloudflare.com, .ngrok-free.app) are allowed automatically.
# FRONTEND_URL=http://localhost:3001

# OAuth redirect base (optional). When set, this URL wins over callback_base from the browser and MUST match Partner Dashboard.
# shopify.app.toml [auth] redirect_urls (e.g. https://splitter.echologyx.com/api/auth/callback) are what Shopify CLI syncs — they do NOT include a random trycloudflare host. If APP_URL is a tunnel, add that tunnel’s Application URL + Allowed redirection URL in Partner Dashboard manually, or OAuth will error on admin.shopify.com/.../oauth/authorize.
# Prefer a stable domain for production: RIPX_OAUTH_REDIRECT_BASE=https://your-stable-domain.com
# RIPX_OAUTH_REDIRECT_BASE=https://splitter.echologyx.com

# Optional: extra hosts allowed for OAuth redirect_uri (comma-separated). Use when Partner Dashboard uses a host not in APP_URL/FRONTEND_URL. Tunnel suffixes (.trycloudflare.com, .ngrok-free.app, .ngrok.io) are always allowed.
# RIPX_OAUTH_ALLOWED_HOSTS=your-app.example.com

# ============================================
# Optional Variables
# ============================================

# App version (optional; defaults to 1.0.0)
# APP_VERSION=1.0.0

# Request timeout in ms (default 60000)
# REQUEST_TIMEOUT_MS=60000

# Node Environment
NODE_ENV=development
# Options: development, production, test

# Server Port
PORT=3000

# Redis (optional; enables background jobs: scheduled tests, archive)
# Session uses memory when not set. Set REDIS_URL to enable Bull queues.
# For docker-compose.dev.yml: redis://localhost:6379
# REDIS_URL=redis://localhost:6379

# Archive job: days after test stop to archive (default 90)
# RIPX_ARCHIVE_DAYS_AFTER=90

# Webhook events retention: purge webhook_events older than N days (default 30, min 7)
# RIPX_WEBHOOK_EVENTS_RETENTION_DAYS=30

# Require consent before tracking (script returns consent_required; storefront must gate events)
# RIPX_CONSENT_REQUIRED=true

# Storefront script.js (App Proxy + /api/track/script.js) embeds activeTests — browser/CDN cache TTL in seconds (default 120, max 3600). Avoid very high values or new tests won’t appear until cache expires.
# RIPX_SCRIPT_CACHE_MAX_AGE=120

# Shipping carrier callback (optional): when set, shipping execute can auto-create/update Shopify CarrierService adapters
# for flat_rate / carrier_quote strategies. Must be an absolute URL Shopify can reach.
# If unset, backend falls back to APP_URL + /api/track/shipping-carrier-rates.
# RIPX_SHIPPING_CARRIER_CALLBACK_URL=https://your-api.example.com/api/track/shipping-carrier-rates

# Checkout price test: GET /api/track/price-resolve, POST /api/track/price-resolve-batch, GET /api/track/price-checkout-diagnostics.
# In production, RIPX_CHECKOUT_PRICE_SECRET is required for resolver endpoints (missing secret => 503).
# Public diagnostics are redacted by default; authenticated app UI uses GET /api/settings/checkout-price-diagnostics for full details.
# Set RIPX_PUBLIC_CHECKOUT_DIAGNOSTICS_FULL=true only when you intentionally want full diagnostics on the public route.
# See docs/SHOPIFY_CHECKOUT_PRICE_RESOLVER.md.
# RIPX_CHECKOUT_PRICE_SECRET=
# RIPX_PUBLIC_CHECKOUT_DIAGNOSTICS_FULL=false
# Assignment proof verification for checkout resolver.
# Default: enabled in production when unset. Set false only for temporary migration windows.
# RIPX_CHECKOUT_REQUIRE_SIGNED_ASSIGNMENT=true
# Dev/preview: allow draft or paused price tests at checkout (discount function resolver). Default false — live checkout only applies running tests.
# RIPX_CHECKOUT_ALLOW_DRAFT_PRICE_TESTS=false
# RIPX_PRICE_ASSIGNMENT_SIGNATURE_SECRET=replace-with-random-32+-char-secret
# RIPX_PRICE_ASSIGNMENT_SIGNATURE_TTL_SEC=86400
# Synthetic readiness probe baseline line total (major units) for verify:price-assignment-readiness (default 100)
# RIPX_ASSIGNMENT_PROBE_LINE_TOTAL=100
# Synthetic readiness probe quantity for verify:price-assignment-readiness (default 1)
# RIPX_ASSIGNMENT_PROBE_QTY=1
# Optional: full URL for POST /api/track/price-resolve-batch (overrides APP_URL + path). Written into extensions/ripx-checkout-discount/src/ripxConfig.js by npm run shopify:checkout-discount:sync-config
# RIPX_PRICE_RESOLVE_BATCH_URL=https://your-api.example.com/api/track/price-resolve-batch
# Optional: full URL for POST /api/track/shipping-resolve-batch (overrides APP_URL + path). Also written into extensions/ripx-checkout-discount/src/ripxConfig.js by npm run shopify:checkout-discount:sync-config
# RIPX_SHIPPING_RESOLVE_BATCH_URL=https://your-api.example.com/api/track/shipping-resolve-batch
# Optional: checkout UI extension endpoints. Written to ignored extensions/ripx-checkout-ui/src/ripxConfig.generated.js by npm run shopify:checkout-ui:sync-config
# RIPX_CHECKOUT_ASSIGNMENT_URL=https://your-api.example.com/api/track/checkout-assignment
# RIPX_CHECKOUT_CONVERSION_URL=https://your-api.example.com/api/track/checkout-conversion
# RIPX_CHECKOUT_UI_TEST_ID=
# RIPX_CHECKOUT_UI_SHOP_DOMAIN=
# Optional: max lines per batch (default 80)
# PRICE_RESOLVE_BATCH_MAX=80
# Max UTF-8 bytes for batch JSON response (default 97280 ≈ 95KB; Shopify Function fetch ~100KB limit)
# PRICE_RESOLVE_BATCH_RESPONSE_MAX_BYTES=97280
# Include targetLineDecimal + reason on each batch line (default: compact JSON for Shopify size limits)
# RIPX_PRICE_BATCH_FULL_RESPONSE=true
# Log warn when price-resolve-batch exceeds this duration ms (default 800; Shopify fetch readTimeout up to 2000)
# PRICE_BATCH_SLOW_LOG_MS=800
# Diagnostics: compare server .env to extensions/ripx-checkout-discount/src/ripxConfig.js (GET price-checkout-diagnostics, verify:price-pipeline). Set true if the API image has no checkout extension folder.
# RIPX_DIAGNOSTICS_SKIP_EXTENSION_CONFIG=true

# Email verification (magic-link): when true or unset, log link instead of sending email
# RIPX_EMAIL_VERIFICATION_STUB=true

# SMTP (login codes, magic links, approval emails). Required for production email.
# AWS SES: use port 587 (STARTTLS); create SMTP credentials in SES console.
SMTP_HOST=email-smtp.eu-west-2.amazonaws.com
SMTP_PORT=587
# SMTP_SECURE=false
SMTP_USER=your_smtp_user
SMTP_PASS=your_smtp_pass
SMTP_FROM=abtesting-noreply@echologyx.com
# Optional Reply-To on outbound mail when the caller does not set one (including test email).
# Does not fix Microsoft 365 filtering by itself; use for support replies.
# SMTP_REPLY_TO=support@yourdomain.com
# Retries on transient SMTP failure (default 3 attempts, exponential backoff from 1s).
# SMTP_MAX_RETRIES=3
# SMTP_RETRY_DELAY_MS=1000
# Server logs "SMTP connection verified" on startup if configured; "SMTP verification failed" = check credentials/port/firewall.
#
# Microsoft 365: if Gmail and other domains receive RipX mail but @yourcompany.com mailboxes never
# do (not even Junk), the tenant is almost certainly quarantining or dropping "same-domain From
# + external path (SES)". RipX cannot override that. Your Exchange admin should: (1) Message trace
# + Quarantine for the recipient and Message-ID; (2) confirm SES DKIM/SPF/DMARC for the From
# domain; (3) add a connector / transport exception for authenticated SES, or relax anti-spoofing
# for that sender. Optional workaround: verify a subdomain in SES (e.g. mail.yourcompany.com) and
# set SMTP_FROM=noreply@mail.yourcompany.com so the visible From is not identical to employee mail.

# Support – email where new tickets are sent (defaults to SMTP_FROM if unset). See docs/CUSTOMER_SUPPORT_IMPLEMENTATION_PLAN.md.
# SUPPORT_EMAIL_TO=your-team@yourdomain.com

# Support ticket retention: optional job can soft-delete tickets with status=closed and resolved_at older than N days (migration 049 adds deleted_at).
# SUPPORT_TICKET_RETENTION_DAYS=90

# AI chatbot – optional. When set, POST /api/support/chat uses OpenAI (gpt-4o-mini by default). When unset, returns a stub message.
# OPENAI_API_KEY=sk-your-openai-key
# OPENAI_CHAT_MODEL=gpt-4o-mini
# OPENAI_CHAT_MAX_TOKENS=500
# OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# RipX AI Agent – authenticated, context-aware assistant. Actions are confirmation-gated and disabled by default.
# SUPPORT_AGENT_ENABLED=true
# Local/dev only: return realistic mock replies without calling OpenAI.
# SUPPORT_AGENT_MOCK_AI=false
# RATE_LIMIT_SUPPORT_AGENT_MAX=20
# SUPPORT_AGENT_ACTIONS_ENABLED=false
# SUPPORT_AGENT_MAX_TOOL_STEPS=4
# SUPPORT_AGENT_MAX_READ_TOOLS=6
# SUPPORT_AGENT_ALLOW_CLIENT_TOOLS=false
# SUPPORT_AGENT_CONFIRMATION_SECRET=replace-with-random-32+-char-secret

# Admin email (standalone): can log in without admin acceptance; comma-separated for multiple.
RIPX_ADMIN_EMAIL=admin@example.com

# First super admin (server setup): set this and run `npm run ensure-superadmin` to create/accept
# the first super admin in the database. Script uses RIPX_SUPERADMIN_EMAIL or RIPX_ADMIN_EMAIL.
# RIPX_SUPERADMIN_EMAIL=admin@example.com


# Session secret for express-session (cookie signing). Production: set explicitly; do not rely on JWT_SECRET fallback.
# SESSION_SECRET=your_session_secret_here

# Optional: Sentry DSN for error reporting (backend + frontend)
# SENTRY_DSN=https://xxx@sentry.io/xxx

# CORS Allowed Origins (comma-separated)
# For standalone: add your admin/site domains (e.g. https://admin.example.com)
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001,http://localhost:5173

# Database SSL (for production; set false for local dev if needed)
DATABASE_SSL_REJECT_UNAUTHORIZED=true
# DATABASE_SSL_CA=/path/to/ca-certificate.pem

# Connection pool: max connections (default prod 20, dev 10; cap 100)
# DATABASE_POOL_MAX=20
# DATABASE_POOL_IDLE_TIMEOUT_MS=30000
# DATABASE_POOL_CONNECT_TIMEOUT_MS=2000

# Statement timeout: abort queries after N ms (e.g. 60000); prevents long queries from holding pool connections
# DATABASE_STATEMENT_TIMEOUT_MS=60000

# Encrypts DB-stored integration secrets (GA4 API secret, BigQuery service account JSON).
# Generate with: openssl rand -base64 32
# After setting this in an existing environment, run: npm run encrypt:integration-secrets
# RIPX_SECRET_ENCRYPTION_KEY=

# Slow query logging: threshold in ms (default 1000); log in production when SLOW_QUERY_LOG_PROD=true
# SLOW_QUERY_MS=2000
# SLOW_QUERY_LOG_PROD=false

# Analytics query verification script:
# npm run verify:analytics-queries prints EXPLAIN plans; add -- --analyze to run EXPLAIN ANALYZE intentionally.
# You can also pass a domain directly: npm run verify:analytics-queries -- --domain=your-store.myshopify.com
# RIPX_EXPLAIN_SHOP_DOMAIN=your-store.myshopify.com
# If unset and the DB has exactly one tenant/shop_settings domain, the script uses that domain automatically.
# RIPX_EXPLAIN_TEST_ID=
# RIPX_EXPLAIN_EVENT_NAMES=page_view,purchase,add_to_cart

# Frontend API URL (for Vite)
# VITE_API_URL=http://localhost:3000/api

# Frontend dev server port (default 3001; backend uses PORT)
# VITE_PORT=3001

# Shopify embedded app: Client ID (required for blank-screen fix in Shopify Admin iframe)
# Use same value as SHOPIFY_API_KEY / the active app config client_id for this environment.
# VITE_SHOPIFY_API_KEY=your_shopify_api_key_here

# Optional: shop domain for frontend (e.g. for Connect or preview URLs when not from Shopify)
# VITE_SHOP_DOMAIN=your-store.myshopify.com

# Optional: Shopify Admin app handle (from Partner dashboard app URL). When set, "Open app" for
# Shopify stores from My domains / Home opens the app inside Shopify Admin instead of standalone.
# Example: if your app URL is admin.shopify.com/store/.../apps/ripx then use ripx
# VITE_SHOPIFY_APP_HANDLE=ripx

# Standalone mode: API key (store in localStorage for admin UI)
# VITE_RIPX_API_KEY=sk_your_api_key_here

# Password-protected Shopify dev stores (preview-document / Pick PDP). Default "sp" on localhost and *.echologyx.com; leave unset on public production.
# RIPX_DEV_STOREFRONT_PASSWORD=sp
# VITE_RIPX_DEV_STOREFRONT_PASSWORD=sp

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
# Default in code: 400/15min (set higher if you see 429 on app load)
RATE_LIMIT_MAX_REQUESTS=400
# Track endpoint (storefront) - higher limit for high traffic; default 2000/15min
# RATE_LIMIT_TRACK_MAX=2000
# Public GET /api/track/price-checkout-diagnostics (default 120/15min; stricter than full track bucket)
# RATE_LIMIT_PRICE_DIAGNOSTICS_MAX=120

# Admin panel - separate bucket; default 120/15min
# RATE_LIMIT_ADMIN_MAX=120

# Admin → Email delivery → Send test email (default 8 per 15 min per IP)
# RATE_LIMIT_MAIL_TEST_MAX=8

# Sensitive admin actions (impersonate, set role) - stricter; default 10/15min per IP
# RATE_LIMIT_SENSITIVE_ADMIN_MAX=10

# Auth (login, magic link, OTP) - limit per IP; default 30/15min. GET /api/auth/install (install link page) is not counted.
# RATE_LIMIT_AUTH_MAX=30

# Tenant registration (POST /api/tenants) - stricter; default 10/15min per IP
# RATE_LIMIT_TENANT_MAX=10

# Client error reporting (POST /api/track/client-error) - stricter; default 100/15min per IP
# RATE_LIMIT_CLIENT_ERROR_MAX=100
# Support ticket submission (POST /api/support) – default 10/15min per IP. Chat has its own limit below.
# RATE_LIMIT_SUPPORT_MAX=10
# Support chat (POST /api/support/chat) – default 40/15min per IP
# RATE_LIMIT_SUPPORT_CHAT_MAX=40

# Health endpoints (/live, /ready, /health and /api/* mirrors) – dedicated bucket; default 300 requests per 60s per IP
# RATE_LIMIT_HEALTH_WINDOW_MS=60000
# RATE_LIMIT_HEALTH_MAX=300

# Heatmap batch: max events per POST /api/track/heatmap (DoS protection; default 500)
# HEATMAP_EVENTS_BATCH_MAX=500

# Body parser limit (default 1mb; increase for large webhooks if needed)
# BODY_LIMIT=1mb

# Logging
LOG_LEVEL=info
# Options: error, warn, info, debug

# Track event logging (noisy)
LOG_TRACK_EVENTS=false

# UI telemetry auth mode:
# - development default: anonymous allowed for POST /api/ui-events (avoid noisy 401 while iterating UI)
# - production default: authenticated only
# Set true to allow anonymous ui-events outside development when intentionally needed.
# RIPX_UI_EVENTS_ALLOW_ANON=false

# BigQuery Export (optional; for analytics data warehouse)
# Exports: events (incremental), heatmap_events (incremental), tests (full only)
# Create tables first: see backend/docs/bigquery_schema.sql
# GCP_PROJECT_ID=your-gcp-project
# GCP_DATASET=ripx_analytics
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account-key.json

# GA4 Integration (optional; forwards events to Google Analytics 4)
# Sends user_properties: ab_test_id, ab_variant_id, ab_shop for segmentation
# GA4_MEASUREMENT_ID=G-XXXXXXXXXX
# GA4_API_SECRET=your_measurement_protocol_api_secret

# ============================================
# Admin Panel
# ============================================
# Local/dev: grant admin to a shop without setting DB role (comma-separated)
# Example: RIPX_ADMIN_SHOP_DOMAINS=my-dev-store.myshopify.com
# RIPX_ADMIN_SHOP_DOMAINS=

# Optional: API key for admin API access (scripts, support tools). Send as X-Admin-API-Key.
# In production, use DB role (see docs/getting-started/ADMIN_SETUP.md) instead of env list.
# ADMIN_API_KEY=

# Optional: Restrict admin panel to specific IPs (comma-separated). When set, only these IPs can access /api/admin/*.
# ADMIN_IP_ALLOWLIST=203.0.113.10,203.0.113.20

# ============================================
# Production Only
# ============================================

# In production, ensure:
# - NODE_ENV=production
# - APP_URL is set to your production domain
# - DATABASE_URL points to production database
# - JWT_SECRET is a strong, random string
# - All security settings are properly configured
