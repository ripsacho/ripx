# RipX Environment Variables
# Copy this file to .env and fill in your values

# ============================================
# Required Variables
# ============================================

# Shopify API Credentials
SHOPIFY_API_KEY=your_shopify_api_key_here
SHOPIFY_API_SECRET=your_shopify_api_secret_here

# Database Configuration
DATABASE_URL=postgresql://username:password@localhost:5432/ripx_db
# Alternative: MongoDB
# MONGODB_URI=mongodb://localhost:27017/ripx_db

# JWT Secret (generate a strong random string)
JWT_SECRET=your_jwt_secret_here_generate_strong_random_string

# Application URL
APP_URL=http://localhost:3000

# ============================================
# Optional Variables
# ============================================

# Node Environment
NODE_ENV=development
# Options: development, production, test

# Server Port
PORT=3000

# Redis Configuration (for session management)
REDIS_URL=redis://localhost:6379

# CORS Allowed Origins (comma-separated)
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001,http://localhost:5173

# Database SSL Configuration (for production)
DATABASE_SSL_REJECT_UNAUTHORIZED=true
# DATABASE_SSL_CA=/path/to/ca-certificate.pem

# Frontend API URL (for Vite)
# VITE_API_URL=http://localhost:3000/api

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Logging
LOG_LEVEL=info
# Options: error, warn, info, debug

# ============================================
# Production Only
# ============================================

# In production, ensure:
# - NODE_ENV=production
# - APP_URL is set to your production domain
# - DATABASE_URL points to production database
# - JWT_SECRET is a strong, random string
# - All security settings are properly configured
