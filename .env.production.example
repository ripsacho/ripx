# Production environment template (copy to .env.production on the server; never commit .env.production)
# On the server, either symlink/copy to `.env` for the Node process or load this file explicitly in your process manager.
# Client ID must match shopify.app.production.toml
# Full variable reference: .env.example | deploy guide: docs/PRODUCTION_ENV_UPDATE_GUIDE.md

# --- Shopify app (required) ---
SHOPIFY_API_KEY=475a569769b25edb8df85288e1be9637
VITE_SHOPIFY_API_KEY=475a569769b25edb8df85288e1be9637
SHOPIFY_API_SECRET=your_production_app_secret
# Must match shopify.app.production.toml [access_scopes] and Partner Dashboard (price, shipping, checkout extensions).
SHOPIFY_SCOPES=read_cart_transforms,read_content,read_delivery_customizations,read_discounts,read_online_store_pages,read_orders,read_payment_customizations,read_products,read_shipping,write_cart_transforms,write_delivery_customizations,write_discounts,write_payment_customizations,write_products,write_shipping

# --- Public URLs (single source of truth) ---
# SHOPIFY_APP_URL, RIPX_OAUTH_REDIRECT_BASE, RIPX_* track URLs, and carrier callback URLs derive from APP_URL at runtime.
APP_URL=https://splitter.echologyx.com
ALLOWED_ORIGINS=https://splitter.echologyx.com
# Set only when the browser UI origin differs from APP_URL (unusual for single-host deploy).
# FRONTEND_URL=https://splitter.echologyx.com
# Optional OAuth override when Partner Dashboard must pin a different host than APP_URL.
# RIPX_OAUTH_REDIRECT_BASE=https://splitter.echologyx.com

# --- Server ---
NODE_ENV=production
PORT=3000
LOG_LEVEL=info
# REQUEST_TIMEOUT_MS=60000

# --- Database (required) ---
DATABASE_URL=postgresql://user:password@localhost:5432/ripx_production
# Managed Postgres (RDS, etc.): true + optional CA. Same-VM Postgres without TLS: false.
DATABASE_SSL_REJECT_UNAUTHORIZED=true
# DATABASE_SSL_CA=/path/to/ca-certificate.pem
# DATABASE_POOL_MAX=20
DATABASE_STATEMENT_TIMEOUT_MS=60000

# --- Auth & sessions (required) ---
# Generate each: openssl rand -hex 32
JWT_SECRET=
SESSION_SECRET=
# Admin email login (comma-separated). Required for admin panel access without DB role setup.
RIPX_ADMIN_EMAIL=admin@example.com
# First super admin bootstrap: npm run ensure-superadmin (uses RIPX_SUPERADMIN_EMAIL or RIPX_ADMIN_EMAIL)
# RIPX_SUPERADMIN_EMAIL=admin@example.com

# --- Checkout, price & shipping tests (required for live A/B tests) ---
# Protects POST /api/track/price-resolve-batch and shipping-resolve-batch; synced into checkout extensions.
RIPX_CHECKOUT_PRICE_SECRET=
# Signs storefront cart line assignment proofs (can match RIPX_CHECKOUT_PRICE_SECRET or be separate).
RIPX_PRICE_ASSIGNMENT_SIGNATURE_SECRET=
RIPX_CHECKOUT_REQUIRE_SIGNED_ASSIGNMENT=true
# RIPX_PRICE_ASSIGNMENT_SIGNATURE_TTL_SEC=86400
# RIPX_SHIPPING_CARRIER_CALLBACK_URL defaults to APP_URL + /api/track/shipping-carrier-rates
# RIPX_PRICE_RESOLVE_BATCH_URL / RIPX_SHIPPING_RESOLVE_BATCH_URL override APP_URL-derived batch URLs (usually leave unset)

# --- Email (required for magic links, login codes, notifications) ---
SMTP_HOST=email-smtp.eu-west-2.amazonaws.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=abtesting-noreply@echologyx.com
RIPX_EMAIL_VERIFICATION_STUB=false
# SUPPORT_EMAIL_TO=your-team@example.com

# --- Redis (recommended for scheduled tests, archive jobs, persistent sessions) ---
# Without REDIS_URL, sessions and Bull queues use in-memory fallback (not ideal on multi-instance hosts).
# REDIS_URL=redis://localhost:6379

# --- Frontend build-time (run before npm run build) ---
# VITE_* is baked into frontend/dist at build time — rebuild after changing these.
# VITE_API_URL=https://splitter.echologyx.com/api
# VITE_SHOPIFY_APP_HANDLE=ripx
# VITE_SHOP_DOMAIN=your-store.myshopify.com

# --- Integrations & encrypted settings (optional) ---
# Required when storing GA4 / BigQuery credentials in Admin → Integrations.
# Generate: openssl rand -base64 32  then: npm run encrypt:integration-secrets
# RIPX_SECRET_ENCRYPTION_KEY=

# --- Optional services ---
# OPENAI_API_KEY=
# OPENAI_CHAT_MODEL=gpt-4o-mini
# SUPPORT_AGENT_ENABLED=true
# SENTRY_DSN=
# GCP_PROJECT_ID=
# GCP_DATASET=ripx_analytics
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account-key.json
# GA4_MEASUREMENT_ID=
# GA4_API_SECRET=

# --- After filling in .env.production on the server ---
# 1. npm run shopify:guard:production:env
# 2. npm run migrate
# 3. npm run shopify:extensions:prepare:production
# 4. npm run build
# 5. npm run shopify:deploy:production:safe
# 6. Restart API process
#
# Readiness checks (copy .env.production → .env or export vars first):
#   npm run verify:price-assignment-readiness
#   npm run verify:shipping-readiness
#   npm run verify:price-go-no-go:strict
