{
  "name": "ripx-frontend",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "copy:storefront": "node -e \"require('fs').copyFileSync(require('path').join(__dirname,'..','shopify','storefront-script.js'), require('path').join(__dirname,'public','ripx-storefront.js'))\"",
    "predev": "npm run copy:storefront",
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "lint": "eslint src --ext .js,.jsx",
    "lint:fix": "eslint src --ext .js,.jsx --fix",
    "test": "jest",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui"
  },
  "dependencies": {
    "@shopify/app-bridge": "^3.7.9",
    "@shopify/app-bridge-react": "^3.7.9",
    "@shopify/polaris": "^12.0.0",
    "@shopify/polaris-icons": "^9.3.1",
    "@tanstack/react-query": "^5.90.21",
    "axios": "^1.7.0",
    "prismjs": "^1.30.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "react-router-dom": "^6.28.0",
    "react-simple-code-editor": "^0.14.1",
    "recharts": "^2.15.0"
  },
  "devDependencies": {
    "@babel/core": "^7.26.0",
    "@babel/preset-env": "^7.26.0",
    "@babel/preset-react": "^7.28.5",
    "@playwright/test": "^1.58.2",
    "@types/react": "^18.2.43",
    "@types/react-dom": "^18.2.17",
    "@vitejs/plugin-react": "^4.2.1",
    "babel-jest": "^29.7.0",
    "eslint": "^8.57.1",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-react": "^7.33.2",
    "eslint-plugin-react-hooks": "^4.6.0",
    "jest": "^29.7.0",
    "prettier": "^3.8.1",
    "terser": "^5.46.0",
    "vite": "^5.4.0"
  },
  "overrides": {
    "minimatch": "^10.2.1"
  }
}
